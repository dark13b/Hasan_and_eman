---
interface Props {
  locale?: "en" | "ar";
  title: string;
  text: string;
  primaryLabel: string;
  secondaryLabel: string;
}

const {
  locale = "en",
  title,
  text,
  primaryLabel,
  secondaryLabel,
} = Astro.props;

const contactHref = locale === "ar" ? "/ar/contact" : "/contact";
const bookHref = locale === "ar" ? "/ar/book" : "/book";
---
<section class="container-shell py-14 md:py-20">
  <div class="border-t border-border pt-12 md:pt-16">
    <div class="grid gap-8 md:grid-cols-[minmax(0,0.28fr)_minmax(0,1fr)] md:gap-12">
      <div class="border-b border-border pb-5 md:border-b-0 md:border-r md:pb-0 md:pr-8">
        <p class="text-xs uppercase tracking-[0.24em] text-fg/42">
          {locale === "ar" ? "بداية مشروع" : "Start a project"}
        </p>
        <p class="mt-4 max-w-[12rem] text-sm leading-6 text-fg/56">
          {locale === "ar"
            ? "مسار هادئ ومباشر للمشاريع الجديدة."
            : "A quiet invitation for new identity work."}
        </p>
      </div>

      <div class="grid gap-8 md:grid-cols-[minmax(0,1fr)_auto] md:items-end">
        <div class="max-w-3xl">
          <h2 class="font-serif text-3xl tracking-[-0.05em] text-fg md:text-[4.25rem] md:leading-[0.96]">
            {title}
          </h2>
          <p class="mt-5 max-w-2xl text-base leading-7 text-fg/70">
            {text}
          </p>
        </div>

        <div class="flex flex-col gap-3 sm:flex-row md:flex-col md:items-start">
          <a
            href={contactHref}
            class="inline-flex min-h-[3rem] items-center justify-center border border-primary bg-primary px-5 text-sm text-white transition-colors duration-200 hover:bg-[#24324f] focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary/30"
          >
            {primaryLabel}
          </a>
          <a
            href={bookHref}
            class="inline-flex min-h-[3rem] items-center justify-center border border-border px-5 text-sm text-fg transition-colors duration-200 hover:border-primary hover:text-primary focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary/30"
          >
            {secondaryLabel}
          </a>
        </div>
      </div>
    </div>
  </div>
</section>
