---
interface Props {
  locale?: "en" | "ar";
  title: string;
  text: string;
  primaryLabel: string;
  secondaryLabel: string;
}

const {
  locale = "en",
  title,
  text,
  primaryLabel,
  secondaryLabel,
} = Astro.props;

const contactHref = locale === "ar" ? "/ar/contact" : "/contact";
const bookHref = locale === "ar" ? "/ar/book" : "/book";
---
<section class="container-shell py-14 md:py-20">
  <div class="border border-border bg-muted px-6 py-10 md:px-10 md:py-14">
    <div class="grid gap-8 md:grid-cols-[minmax(0,1.2fr)_minmax(0,0.8fr)] md:items-end">
      <div class="max-w-2xl">
        <p class="text-xs uppercase tracking-[0.24em] text-fg/48">
          {locale === "ar" ? "بداية مشروع" : "Start a project"}
        </p>
        <h2 class="mt-4 font-serif text-3xl tracking-[-0.05em] text-fg md:text-5xl">
          {title}
        </h2>
        <p class="mt-5 max-w-xl text-base leading-7 text-fg/70">
          {text}
        </p>
      </div>

      <div class="flex flex-col gap-3 sm:flex-row md:justify-end">
        <a
          href={contactHref}
          class="inline-flex min-h-[3rem] items-center justify-center border border-primary bg-primary px-5 text-sm text-white transition-colors duration-200 hover:bg-[#24324f] focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary/30"
        >
          {primaryLabel}
        </a>
        <a
          href={bookHref}
          class="inline-flex min-h-[3rem] items-center justify-center border border-border px-5 text-sm text-fg transition-colors duration-200 hover:border-primary hover:text-primary focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary/30"
        >
          {secondaryLabel}
        </a>
      </div>
    </div>
  </div>
</section>
