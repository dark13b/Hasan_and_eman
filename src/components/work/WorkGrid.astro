---
import ProjectsHero from "./ProjectsHero.astro";
import ProjectsIndex from "./ProjectsIndex";
import ProjectsCta from "./ProjectsCta.astro";

const { locale = "en", dict } = Astro.props;
---
<>
  <ProjectsHero
    eyebrow={dict.workIndex.eyebrow}
    title={dict.workIndex.title}
    intro={dict.workIndex.intro}
  />
  <ProjectsIndex client:load locale={locale} />
  <ProjectsCta
    locale={locale}
    title={dict.workIndex.ctaTitle}
    text={dict.workIndex.ctaText}
    primaryLabel={dict.workIndex.ctaPrimary}
    secondaryLabel={dict.workIndex.ctaSecondary}
  />
</>
